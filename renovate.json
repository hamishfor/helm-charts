{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitTypeAll(feat)"
  ],
  "ignoreDeps": [
    "postgresql",
    "redis"
  ],
  "packageRules": [
    {
      "matchManagers": ["helmv3", "helm-values"],
      "postUpgradeTasks": {
        "commands": [
          "bash -c 'cd {{{parentDir}}} && VERSION=$(grep \"^version:\" Chart.yaml | awk \"{print \\$2}\") && IFS=. read -r MAJOR MINOR PATCH <<< \"$VERSION\" && PATCH=$((PATCH+1)) && sed -i \"s/^version: .*/version: $MAJOR.$MINOR.$PATCH/\" Chart.yaml'"
        ],
        "fileFilters": ["charts/**/Chart.yaml"]
      }
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^charts/.+/Chart\\.yaml$"
      ],
      "matchStrings": [
        "image:\\s+\"(?<depName>[a-zA-Z0-9/._-]+):(?<currentValue>[a-zA-Z0-9._@:-]+)\""
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^charts/.+/values\\.yaml$"
      ],
      "matchStrings": [
        "\\s+repository:\\s+\"?(?<depName>[a-zA-Z0-9/._-]+)\"?\\n\\s+tag:\\s+\"?(?<currentValue>[a-zA-Z0-9._@:-]+)\"?"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^charts/.+/Chart\\.yaml$"
      ],
      "matchStrings": [
        "# image: \"(?<depName>[a-zA-Z0-9/._-]+)\"\\nappVersion:\\s+\"?(?<currentValue>v?[a-zA-Z0-9._-]+)\"?"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "helmv3": {
    "enabled": true
  }
}
